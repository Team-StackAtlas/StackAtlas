# Supabase backend (account/profile/saved/hidden/follows/notifications).
# Account features are env-gated: without these the app runs fully offline with
# mock catalog data and auth is disabled. With them set, accounts activate.
# Find these in your Supabase project: Settings → API.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_ANON_PUBLIC_KEY"
